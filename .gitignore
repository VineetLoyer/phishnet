*.py[cod]
*$py.class
.venv/
venv/
env/
.eggs/
*.egg-info/
.pytest_cache/
.mypy_cache/
.ipynb_checkpoints/

# --- OS ---
.DS_Store
Thumbs.db
desktop.ini

# --- IDE ---
.vscode/
.idea/
*.swp

# --- Build / packaging ---
*.tar.gz
*.tgz
dist/
build/

