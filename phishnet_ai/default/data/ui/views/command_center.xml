<dashboard version="1.1" theme="dark">
  <label>PhishNet AI — Command Center</label>
  <description>Autonomous phishing triage overview. The agent investigates every alert; analysts review only what's flagged.</description>

  <!-- Headline KPIs: the Maya story in four numbers -->
  <row>
    <panel>
      <title>Alerts Processed</title>
      <single>
        <search>
          <query>| inputlookup phishnet_decisions | stats count</query>
        </search>
        <option name="colorBy">value</option>
        <option name="rangeColors">["0x53a051","0x53a051"]</option>
        <option name="numberPrecision">0</option>
      </single>
    </panel>
    <panel>
      <title>Auto-Closed (False Positives)</title>
      <single>
        <search>
          <query>| inputlookup phishnet_decisions | where status="confirmed" AND recommended_action="close" | stats count</query>
        </search>
        <option name="colorBy">value</option>
        <option name="rangeColors">["0x006d9c","0x006d9c"]</option>
        <option name="numberPrecision">0</option>
      </single>
    </panel>
    <panel>
      <title>Flagged for Review</title>
      <single>
        <search>
          <query>| inputlookup phishnet_decisions | where recommended_action="review" OR recommended_action="escalate" | stats count</query>
        </search>
        <option name="colorBy">value</option>
        <option name="rangeColors">["0xf8be34","0xf8be34"]</option>
        <option name="numberPrecision">0</option>
      </single>
    </panel>
    <panel>
      <title>Real Threats (Payload Executed)</title>
      <single>
        <search>
          <query>| inputlookup phishnet_decisions | where verdict="targeted_attack" | stats count</query>
        </search>
        <option name="colorBy">value</option>
        <option name="rangeColors">["0xdc4e41","0xdc4e41"]</option>
        <option name="numberPrecision">0</option>
      </single>
    </panel>
  </row>

  <!-- Verdict mix + analyst time saved -->
  <row>
    <panel>
      <title>Verdict Breakdown</title>
      <chart>
        <search>
          <query>| inputlookup phishnet_decisions | stats count by verdict | sort - count</query>
        </search>
        <option name="charting.chart">pie</option>
        <option name="charting.legend.placement">right</option>
      </chart>
    </panel>
    <panel>
      <title>Analyst Time Saved (est.)</title>
      <single>
        <search>
          <!-- 25 min saved per auto-closed alert that an analyst would have triaged manually -->
          <query>| inputlookup phishnet_decisions | where status="confirmed" AND recommended_action="close" | stats count AS fp | eval minutes_saved = fp*25 | eval hours_saved = round(minutes_saved/60,1) | fields hours_saved</query>
        </search>
        <option name="unit">hours</option>
        <option name="colorBy">value</option>
        <option name="rangeColors">["0x53a051","0x53a051"]</option>
      </single>
    </panel>
  </row>

  <!-- The review queue: what Maya actually works on -->
  <row>
    <panel>
      <title>Review Queue — Flagged Alerts (click a row to investigate)</title>
      <table>
        <search>
          <query>| inputlookup phishnet_decisions | where recommended_action!="close" | table alert_id, verdict, confidence, recommended_action, status, reasoning | sort - confidence</query>
        </search>
        <option name="count">20</option>
        <format type="color" field="verdict">
          <colorPalette type="map">{"targeted_attack":#dc4e41,"phishing":#f8be34,"legitimate":#53a051}</colorPalette>
        </format>
        <drilldown>
          <link>/app/phishnet_ai/blast_radius?form.alert_tok=$row.alert_id$</link>
        </drilldown>
      </table>
    </panel>
  </row>
</dashboard>
